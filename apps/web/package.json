{
  "name": "@busos/web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "build:cloudflare": "npx @opennextjs/cloudflare build --dangerouslyUseUnsupportedNextVersion",
    "preview:cloudflare": "npx @opennextjs/cloudflare build --dangerouslyUseUnsupportedNextVersion && npx @opennextjs/cloudflare preview",
    "deploy:cloudflare": "npx @opennextjs/cloudflare build --dangerouslyUseUnsupportedNextVersion && npx @opennextjs/cloudflare deploy",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@prisma/client": "^5.0.0",
    "bcryptjs": "^3.0.3",
    "clsx": "^2.1.0",
    "jose": "^6.2.2",
    "lucide-react": "^0.400.0",
    "next": "14.2.35",
    "openai": "^6.33.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "sonner": "^1.4.0",
    "stripe": "^14.0.0",
    "tailwind-merge": "^2.2.0"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "^1.17.0",
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.0",
    "autoprefixer": "^10.0.0",
    "eslint": "^8.57.0",
    "eslint-config-next": "14.2.35",
    "postcss": "^8.0.0",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.0.0",
    "vitest": "^3.2.4",
    "wrangler": "^3.99.0"
  }
}
